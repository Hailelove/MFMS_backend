// =========================
// DATA SOURCE & GENERATOR
// =========================
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// =========================
// ENUMS
// =========================

enum RoleName {
  ADMIN
  MEMBER
}

enum MemberStatus {
  PENDING
  ACTIVE
  SUSPENDED
  INACTIVE
  CLOSED
}

enum EmploymentStatus {
  ACTIVE
  RESIGNED
  RETIRED
  TERMINATED
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  ADJUSTMENT
}

enum SavingCategory {
  INITIAL_SAVING
  MONTHLY_SAVING
  ADDITIONAL_SAVING
  WITHDRAWAL
  ADJUSTMENT
}

enum ShareTransactionType {
  INITIAL_SHARE
  ADDITIONAL_SHARE
  ADJUSTMENT
}

enum LedgerTransactionType {
  DEPOSIT
  WITHDRAWAL
  TRANSFER
  ADJUSTMENT
}

enum LoanStatus {
  PENDING
  QUEUED            // Waiting for Fund
  APPROVED
  REJECTED
  DISBURSED
  ACTIVE
  COMPLETED
  OVERDUE
  DEFAULTED
}

enum PaymentMethod {
  CASH
  BANK
  PAYROLL
}



enum MaritalStatus {
  SINGLE
  MARRIED
  DIVORCED
  WIDOWED
} 

enum EmploymentType {
  PERMANENT
  CONTRACT
  TEMPORARY
}

enum GuarantorStatus {
  PENDING
  APPROVED
  REJECTED
  RELEASED
}

enum PayrollVerificationStatus {
  PENDING
  VERIFIED
  DISCREPANCY
}

enum LedgerType {
  BANK
  UNION
}

// =========================
// SYSTEM CONFIGURATION
// =========================
model SystemConfiguration {
  id                        Int      @id @default(autoincrement())
  systemName                String   @default("University Saving, Share, Credit and Loan Management System")
  cooperativeInfo           String?
  fiscalYear                String?
  defaultCurrency           String   @default("ETB")
  
  minMonthlySaving          Decimal  @db.Decimal(12, 2)
  minMonthlyShare           Decimal  @db.Decimal(12, 2)
  shareUnitPrice            Decimal  @db.Decimal(12, 2)
  defaultLoanInterestRate   Decimal  @db.Decimal(5, 2)
  maxLoanMultiplier         Decimal  @db.Decimal(5, 2)
  latePaymentPenaltyPercent Decimal  @db.Decimal(5, 2)
  defaultRepaymentPeriod    Int      // in months
  gracePeriodDays           Int
  maxActiveLoansPerMember   Int
  minMembershipDurationDays Int

  sessionTimeoutMinutes     Int      @default(15)
  
  updatedAt                 DateTime @updatedAt
  updatedById               Int?
  updatedBy                 User?    @relation(fields: [updatedById], references: [id], onDelete: SetNull)
}

// =========================
// ROLES & USERS
// =========================

model Role {
  id    Int      @id @default(autoincrement())
  name  RoleName @unique
  users User[]
}

model User {
  id           Int       @id @default(autoincrement())
  username     String    @unique
  email        String?   @unique
  passwordHash String
  isActive     Boolean   @default(true)
  
  lastLogin    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  roleId Int
  role   Role @relation(fields: [roleId], references: [id])

  member Member?

  savingsCreated        Saving[]
  sharesCreated         Share[]
  loansApproved         Loan[]          @relation("LoanApprovedBy")
  loansDisbursed        Loan[]          @relation("LoanDisbursedBy")
  guarantorsActioned    Guarantor[]     @relation("GuarantorActionedBy")
  payrollUploads        PayrollUpload[]
  ledgersCreated        Ledger[]
  auditLogs             AuditLog[]
  notifications         Notification[]
  loanRepayments        LoanRepayment[]
  documents             Document[]
  configurationsUpdated SystemConfiguration[]
}

// =========================
// CAMPUS & STAFF
// =========================

model Campus {
  id          Int      @id @default(autoincrement())
  name          String
  code          String  @unique
  location      String?
  
  status        Boolean @default(true)
  description   String?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  members       Member[]
  campusStaffTypes CampusStaffType[]
}

model StaffType {
  id      Int      @id @default(autoincrement())
  name    String   @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members Member[]
  campusStaffTypes CampusStaffType[]
}


model CampusStaffType {
  id           Int @id @default(autoincrement())
  campusId    Int
  staffTypeId Int

  campus    Campus    @relation(fields: [campusId], references: [id], onDelete: Cascade)
  staffType StaffType @relation(fields: [staffTypeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([campusId, staffTypeId])
}

// =========================
// MEMBER
// =========================

model Member {
  id                  Int      @id @default(autoincrement())
  membershipNo        String   @unique
  employeeId          String   @unique

  fullName            String
  gender              String?
  dateOfBirth         DateTime?

  phone               String?  @unique
  email               String?

  initialSavingAmount Decimal  @db.Decimal(12,2)
  initialShareAmount  Decimal  @db.Decimal(12,2)

  residentialAddress  String?
  nationalId          String?

  emergencyContact    String?
  emergencyContactRel String?

  maritalStatus       MaritalStatus?

  // Employment
  department          String?
  collegeFaculty      String?
  officeUnit          String?
  position            String?
  employmentType      EmploymentType?
  monthlySalary       Decimal  @db.Decimal(12, 2)
  dateOfEmployment    DateTime?
  employmentStatus    EmploymentStatus @default(ACTIVE)

  // Education
  highestEducation       String?
  fieldOfStudy           String?
  educationalInstitution String?
  graduationYear         Int?

  // Membership
  status              MemberStatus @default(PENDING)
  registrationDate    DateTime     @default(now())
  approvalDate        DateTime?
  membershipRemarks   String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  campusId Int
campus Campus @relation(fields: [campusId], references: [id], onDelete: Restrict)

  // Foreign Key for StaffType (Optional)
  staffTypeId Int?

  staffType StaffType? @relation(fields: [staffTypeId], references: [id])
  userId Int?  @unique
  user   User? @relation(fields: [userId], references: [id])

  savings        Saving[]
  shares         Share[]
  loans          Loan[]
  ledgers        Ledger[]
  payrollRecords PayrollRecord[]
  guarantors     Guarantor[]
  documents      Document[]
  memberBalance  MemberBalance?
  

  @@index([campusId])
  @@index([status])
}

// =========================
// SAVINGS
// =========================

model Saving {
  id       Int    @id @default(autoincrement())

  memberId Int
  // STRICT RULE: Financial records lock the parent member from deletion
  member   Member @relation(fields: [memberId], references: [id], onDelete: Restrict)

  type                 TransactionType
  category             SavingCategory
  amount               Decimal @db.Decimal(12, 2)

  isInitialTransaction Boolean @default(false)

  paymentMethod PaymentMethod
  payrollMonth  DateTime?
  referenceNo   String?
  remarks       String?

  transactionDate DateTime @default(now())

  createdById Int?
  createdBy   User? @relation(fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([memberId, transactionDate])
  @@index([memberId, type])
  @@unique([memberId, referenceNo])
}

// =========================
// SHARES (እጣ)
// =========================

model Share {
  id       Int    @id @default(autoincrement())

  memberId Int
  // STRICT RULE: Financial records lock the parent member from deletion
  member   Member @relation(fields: [memberId], references: [id], onDelete: Restrict)

  transactionType ShareTransactionType
  quantity        Int
  unitPrice       Decimal @db.Decimal(12, 2)
  totalAmount     Decimal @db.Decimal(12, 2)

  cumulativeBalance Decimal @db.Decimal(12, 2)

  isInitialTransaction Boolean @default(false)

  contributionDate DateTime @default(now())

  paymentMethod PaymentMethod
  referenceNo   String?
  remarks       String?

  createdById Int?
  createdBy   User? @relation(fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([memberId, contributionDate])
  @@index([memberId, transactionType])
  @@unique([memberId, referenceNo])
}

// =========================
// MEMBER BALANCE
// =========================
model MemberBalance {
  id Int @id @default(autoincrement())

  memberId Int @unique
  // STRICT RULE: Balances must be handled before a member can be deleted
  member   Member @relation(fields: [memberId], references: [id], onDelete: Restrict)

  savingBalance Decimal @default(0) @db.Decimal(12,2)
  shareBalance  Decimal @default(0) @db.Decimal(12,2)

  activeLoanBalance Decimal @default(0) @db.Decimal(12,2)
  totalLoanPaid     Decimal @default(0) @db.Decimal(12,2)

  registeredSavingAmount Decimal @default(0) @db.Decimal(12,2)
  registeredShareAmount  Decimal @default(0) @db.Decimal(12,2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =========================
// LOAN TYPES
// =========================

model LoanType {
  id            Int     @id @default(autoincrement())
  name          String
  interestRate  Decimal @db.Decimal(5, 2)
  maxMultiplier Decimal @db.Decimal(5, 2)

  loans Loan[]
}

// =========================
// LOANS (FIFO SUPPORT)
// =========================

model Loan {
  id Int @id @default(autoincrement())

  memberId Int
  // STRICT RULE: Financial records lock the parent member from deletion
  member   Member @relation(fields: [memberId], references: [id], onDelete: Restrict)

  loanTypeId Int
  loanType   LoanType @relation(fields: [loanTypeId], references: [id], onDelete: Restrict)

  loanPurpose        String?
  requestedAmount    Decimal  @db.Decimal(12, 2)
  approvedAmount     Decimal? @db.Decimal(12, 2)
  
  currentSavingBalance Decimal @db.Decimal(12, 2)
  currentShareBalance  Decimal @db.Decimal(12, 2)
  existingLoanBalance  Decimal? @db.Decimal(12, 2)

  interestRate       Decimal? @db.Decimal(5, 2)
  repaymentPeriod    Int?
  monthlyInstallment Decimal? @db.Decimal(12, 2)

  applicationDate  DateTime  @default(now())
  approvalDate     DateTime?
  disbursementDate DateTime?

  status LoanStatus @default(PENDING)

  queuePosition Int?

  approvedById Int?
  approvedBy   User? @relation("LoanApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)

  disbursedById Int?
  disbursedBy   User? @relation("LoanDisbursedBy", fields: [disbursedById], references: [id], onDelete: SetNull)

  guarantors Guarantor[]
  repayments LoanRepayment[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([status, applicationDate])
  @@index([status, queuePosition])
  @@index([memberId, status])
}

// =========================
// GUARANTORS
// =========================

model Guarantor {
  id Int @id @default(autoincrement())

  loanId Int
  loan   Loan @relation(fields: [loanId], references: [id])

  memberId Int
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  guaranteedAmount Decimal @db.Decimal(12, 2)
  employmentStatus String?

  status GuarantorStatus @default(PENDING)

  approvalDate DateTime?
  remarks      String?

  actionedById Int?
  actionedBy   User? @relation("GuarantorActionedBy", fields: [actionedById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =========================
// LOAN REPAYMENTS
// =========================

model LoanRepayment {
  id Int @id @default(autoincrement())

  loanId Int
  // STRICT RULE: Repayments must be preserved; loan deletion is blocked
  loan   Loan @relation(fields: [loanId], references: [id], onDelete: Restrict)

  amount      Decimal  @db.Decimal(12, 2)
  paymentDate DateTime @default(now())

  paymentMethod PaymentMethod
  referenceNo   String?

  createdById Int?
  createdBy   User? @relation(fields: [createdById], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =========================
// PAYROLL
// =========================

model PayrollUpload {
  id           Int      @id @default(autoincrement())
  payrollMonth DateTime
  payrollYear  Int
  fileName     String?

  uploadDate DateTime @default(now())

  uploadedById Int
  uploadedBy   User @relation(fields: [uploadedById], references: [id], onDelete: Restrict)

  records PayrollRecord[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PayrollRecord {
  id Int @id @default(autoincrement())

  uploadId Int
  upload   PayrollUpload @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  employeeId   String
  employeeName String?
  campusName   String?
  department   String?

  grossSalary     Decimal @db.Decimal(12, 2)
  savingDeduction Decimal @db.Decimal(12, 2)
  shareDeduction  Decimal @db.Decimal(12, 2)
  loanDeduction   Decimal @db.Decimal(12, 2)
  otherDeductions Decimal @db.Decimal(12, 2)
  netSalary       Decimal @db.Decimal(12, 2)

  matchedMemberId Int?
  member          Member? @relation(fields: [matchedMemberId], references: [id], onDelete: SetNull)

  verificationStatus PayrollVerificationStatus @default(PENDING)

  remarks String?

  @@index([employeeId])
  @@unique([employeeId, uploadId])
}

// =========================
// LEDGERS
// =========================

model Ledger {
  id Int @id @default(autoincrement())

  ledgerType LedgerType

  transactionDate DateTime @default(now())

  transactionType LedgerTransactionType

  category String

  amount Decimal @db.Decimal(12,2)

  balance Decimal @db.Decimal(12,2)

  memberId Int?
  member Member? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  createdById Int
  createdBy User @relation(fields: [createdById], references: [id], onDelete: Restrict)

  referenceNo String?

  description String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

// =========================
// DOCUMENTS
// =========================

model Document {
  id Int @id @default(autoincrement())

  memberId Int
  member   Member @relation(fields: [memberId], references: [id], onDelete: Cascade)

  type     String
  filePath String

  uploadedAt DateTime @default(now())

  uploadedById Int?
  uploadedBy   User? @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
}

// =========================
// NOTIFICATIONS
// =========================

model Notification {
  id Int @id @default(autoincrement())

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  title   String
  message String
  type    String

  isRead Boolean @default(false)

  createdAt DateTime @default(now())
}

// =========================
// AUDIT LOG
// =========================

model AuditLog {
  id Int @id @default(autoincrement())

  userId Int?
  user   User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  action    String
  tableName String
  recordId  Int?

  oldValue Json?
  newValue Json?

  createdAt DateTime @default(now())
}